---
import { siteConfig, getClientConfig } from "../config/site";

const clientConfig = getClientConfig();
const { username, hostname, path } = siteConfig.identity;
const crt = siteConfig.theme.crtEffect;
---

<div
  class:list={["term", { "term--crt": crt }]}
  aria-label="Interaktives Terminal"
  data-terminal
>
  <script
    type="application/json"
    id="terminal-config"
    set:html={JSON.stringify(clientConfig)}
  />

  <div class="term-body" data-term-scroll>
    <div
      class="term-output"
      data-term-output
      role="log"
      aria-live="polite"
      aria-relevant="additions"
    >
    </div>

    <form class="term-input-row" data-term-form autocomplete="off">
      <label class="sr-only" for="term-input">Terminal-Befehl</label>
      <span class="prompt" aria-hidden="true">
        <span class="prompt-user">{username}</span><span class="prompt-at">@</span><span class="prompt-host">{hostname}</span><span class="prompt-colon">:</span><span class="prompt-path">{path}</span><span class="prompt-dollar">$</span>
      </span>
      <input
        id="term-input"
        class="term-input"
        data-term-input
        type="text"
        spellcheck="false"
        autocapitalize="off"
        autocorrect="off"
        enterkeyhint="send"
        disabled
      />
    </form>
  </div>
</div>

<script>
  import { initTerminal } from "../scripts/terminal";

  const root = document.querySelector<HTMLElement>("[data-terminal]");
  const configEl = document.getElementById("terminal-config");
  if (root && configEl?.textContent) {
    const config = JSON.parse(configEl.textContent);
    initTerminal(root, config);
  }
</script>

<style>
  .term {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
    background: var(--surface);
    color: var(--text);
    position: relative;
  }

  .term--crt::before {
    content: "";
    pointer-events: none;
    position: absolute;
    inset: 0;
    z-index: 2;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.07) 2px,
      rgba(0, 0, 0, 0.07) 4px
    );
    opacity: 0.5;
  }

  .term-body {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 0.75rem 0.85rem 0.9rem;
    scrollbar-width: thin;
    scrollbar-color: var(--accent-dim) transparent;
  }

  .term-body::-webkit-scrollbar {
    width: 8px;
  }
  .term-body::-webkit-scrollbar-thumb {
    background: var(--accent-dim);
    border-radius: 2px;
  }

  .term-output {
    white-space: pre-wrap;
    word-break: break-word;
  }

  .term-output :global(.term-block) {
    margin: 0;
  }

  .term-output :global(.term-line) {
    min-height: 1.5em;
  }

  .term-output :global(.muted) {
    color: var(--muted);
  }

  .term-output :global(.accent) {
    color: var(--accent);
    font-weight: 500;
  }

  .term-output :global(.error) {
    color: var(--error);
  }

  .term-output :global(.input-line) {
    margin-top: 0.1rem;
  }

  .term-output :global(.cmd-echo) {
    color: var(--text);
  }

  .term-input-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.1rem;
  }

  .prompt,
  .term :global(.prompt) {
    flex-shrink: 0;
    font-weight: 500;
  }

  /* :global — auch für per JS eingefügte Prompt-Zeilen */
  .term :global(.prompt-user),
  .prompt-user {
    color: var(--prompt-user);
  }
  .term :global(.prompt-at),
  .term :global(.prompt-colon),
  .term :global(.prompt-dollar),
  .prompt-at,
  .prompt-colon,
  .prompt-dollar {
    color: var(--text);
  }
  .term :global(.prompt-host),
  .prompt-host {
    color: var(--prompt-host);
  }
  .term :global(.prompt-path),
  .prompt-path {
    color: var(--prompt-path);
  }
  .term :global(.prompt-dollar),
  .prompt-dollar {
    margin-left: 0.15rem;
  }

  .term-input {
    flex: 1;
    min-width: 8ch;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font: inherit;
    caret-color: var(--cursor);
    padding: 0;
  }

  .term-input:disabled {
    opacity: 0.5;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
