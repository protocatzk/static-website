---
import { siteConfig, getDesktopClientConfig } from "../config/site";
import XWindow from "./XWindow.astro";
import Terminal from "./Terminal.astro";

const desktop = siteConfig.desktop;
const desktopClient = getDesktopClientConfig();

const workspaces = Array.from(
  { length: desktop.panel.workspaces },
  (_, i) => i + 1,
);
---

<div
  class:list={[
    "desktop",
    `wallpaper-${desktop.wallpaper}`,
    `panel-${desktop.panel.position}`,
  ]}
  data-desktop
>
  <script
    type="application/json"
    id="desktop-config"
    set:html={JSON.stringify(desktopClient)}
  />

  <div class="desktop-wallpaper" data-desktop-surface aria-hidden="true"></div>

  <!-- Desktop icons -->
  <div class="desktop-icons" aria-label="Desktop">
    {
      desktop.icons.map((icon) => (
        <button
          type="button"
          class="desk-icon"
          data-desktop-icon
          data-action={icon.action}
          data-icon-id={icon.id}
          title={icon.label}
        >
          <span class="desk-icon-glyph" aria-hidden="true">
            {icon.glyph}
          </span>
          <span class="desk-icon-label">{icon.label}</span>
        </button>
      ))
    }
  </div>

  <!-- Windows -->
  <div class="window-layer">
    <XWindow
      id="term"
      title={siteConfig.window.title}
      appName={siteConfig.window.appName}
    >
      <Terminal />
    </XWindow>
  </div>

  <!-- Root menu (right-click / Menu button) -->
  <div class="root-menu" data-root-menu role="menu" aria-label="Root menu">
    <div class="root-menu-header">{desktop.wmName}</div>
    <button type="button" class="root-menu-item" role="menuitem" data-menu-action="open-term">
      Terminal öffnen
    </button>
    <button type="button" class="root-menu-item" role="menuitem" data-menu-action="minimize-term">
      Terminal iconify
    </button>
    <div class="root-menu-sep" role="separator"></div>
    <button type="button" class="root-menu-item" role="menuitem" data-menu-action="about-wm">
      About {desktop.wmName}…
    </button>
  </div>

  <!-- Panel (IceWM / Fluxbox / XFCE-ish) -->
  <nav
    class="panel"
    data-panel
    aria-label="Panel"
  >
    <button
      type="button"
      class="panel-menu-btn"
      data-menu-btn
      aria-haspopup="menu"
      aria-expanded="false"
    >
      <span class="panel-menu-mark" aria-hidden="true">◆</span>
      {desktop.panel.menuLabel}
    </button>

    <div class="panel-tasks">
      <button
        type="button"
        class="panel-task is-active"
        data-task-term
        aria-pressed="true"
      >
        <span class="panel-task-icon" aria-hidden="true">&gt;_</span>
        <span class="panel-task-label">{siteConfig.window.appName}</span>
      </button>
    </div>

    {
      desktop.panel.showWorkspaces && (
        <div class="panel-workspaces" aria-label="Workspaces">
          {workspaces.map((n) => (
            <span
              class:list={[
                "ws",
                { "is-current": n === desktop.panel.activeWorkspace },
              ]}
              title={`Workspace ${n}`}
            >
              {n}
            </span>
          ))}
        </div>
      )
    }

    <div class="panel-tray">
      <span class="panel-wm-name" title={`Window manager: ${desktop.wmName}`}>
        {desktop.wmName}
      </span>
      {
        desktop.panel.showClock && (
          <time class="panel-clock" data-panel-clock datetime="">
            --:--
          </time>
        )
      }
    </div>
  </nav>
</div>

<script>
  import { initDesktop } from "../scripts/desktop";

  const root = document.querySelector<HTMLElement>("[data-desktop]");
  const cfgEl = document.getElementById("desktop-config");
  if (root && cfgEl?.textContent) {
    const config = JSON.parse(cfgEl.textContent);
    initDesktop(root, config);
  }
</script>

<style>
  .desktop {
    position: relative;
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    background: var(--background);
    color: var(--text);
    user-select: none;
  }

  .desktop-wallpaper {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: auto;
  }

  /* Wallpaper variants — Linux desktop, not stock OS wallpapers */
  .wallpaper-slate .desktop-wallpaper {
    background:
      radial-gradient(ellipse 120% 80% at 50% 100%, #1e2820 0%, transparent 55%),
      linear-gradient(160deg, #1a1f1a 0%, #121612 50%, #0e120e 100%);
  }

  .wallpaper-grid .desktop-wallpaper {
    background-color: #161a16;
    background-image:
      linear-gradient(rgba(57, 255, 20, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(57, 255, 20, 0.04) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  .wallpaper-mesh .desktop-wallpaper {
    background-color: #141814;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(46, 90, 46, 0.35) 0%, transparent 42%),
      radial-gradient(circle at 80% 70%, rgba(30, 50, 40, 0.4) 0%, transparent 45%),
      repeating-linear-gradient(
        -12deg,
        transparent,
        transparent 11px,
        rgba(255, 255, 255, 0.015) 11px,
        rgba(255, 255, 255, 0.015) 12px
      );
  }

  /* —— Desktop icons —— */
  .desktop-icons {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 84px;
  }

  .desk-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 6px 4px;
    border: 1px solid transparent;
    background: transparent;
    color: #e8ffe8;
    font: inherit;
    font-size: 0.72rem;
    cursor: default;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.9);
  }

  .desk-icon:hover {
    background: rgba(57, 255, 20, 0.08);
    border-color: rgba(57, 255, 20, 0.2);
  }

  .desk-icon.is-selected {
    background: rgba(46, 90, 46, 0.45);
    border-color: rgba(57, 255, 20, 0.45);
  }

  .desk-icon:focus-visible {
    outline: 1px dotted var(--accent);
  }

  .desk-icon-glyph {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
    font-weight: 700;
    background: linear-gradient(180deg, #2a3a2a 0%, #1a241a 100%);
    border: 1px solid #4a5a4a;
    box-shadow:
      inset 1px 1px 0 rgba(255, 255, 255, 0.08),
      1px 1px 0 rgba(0, 0, 0, 0.4);
    color: var(--accent);
  }

  .desk-icon-label {
    text-align: center;
    line-height: 1.2;
    word-break: break-word;
    max-width: 100%;
  }

  /* —— Window layer (full desktop; panel height clamped in WM JS) —— */
  .window-layer {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
  }

  .window-layer :global(.xwin) {
    pointer-events: auto;
  }

  /* —— Root menu —— */
  .root-menu {
    display: none;
    position: absolute;
    z-index: 100;
    min-width: 200px;
    padding: 2px;
    background: var(--wm-panel-bg);
    border: 1px solid var(--wm-panel-highlight);
    box-shadow:
      2px 2px 0 rgba(0, 0, 0, 0.5),
      inset 1px 1px 0 rgba(255, 255, 255, 0.06);
  }

  .root-menu.is-open {
    display: block;
  }

  .root-menu-header {
    padding: 4px 10px;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--wm-title-active-fg);
    background: var(--wm-title-active-bg);
    margin-bottom: 2px;
  }

  .root-menu-item {
    display: block;
    width: 100%;
    text-align: left;
    padding: 5px 12px;
    border: none;
    background: transparent;
    color: var(--wm-panel-fg);
    font: inherit;
    font-size: 0.8rem;
    cursor: default;
  }

  .root-menu-item:hover,
  .root-menu-item:focus-visible {
    background: var(--wm-title-active-bg);
    color: var(--wm-title-active-fg);
    outline: none;
  }

  .root-menu-sep {
    height: 1px;
    margin: 3px 4px;
    background: var(--wm-panel-border);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  /* —— Panel —— */
  .panel {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 50;
    height: 32px;
    display: flex;
    align-items: stretch;
    gap: 4px;
    padding: 2px 4px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--wm-panel-bg) 88%, white) 0%,
      var(--wm-panel-bg) 40%,
      color-mix(in srgb, var(--wm-panel-bg) 88%, black) 100%
    );
    border-top: 1px solid var(--wm-panel-highlight);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    color: var(--wm-panel-fg);
    font-size: 0.78rem;
  }

  .panel-top .panel {
    top: 0;
    bottom: auto;
    border-top: none;
    border-bottom: 1px solid var(--wm-panel-highlight);
  }

  .panel-menu-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0 10px;
    border: 1px solid var(--wm-button-border);
    background: var(--wm-button-bg);
    color: inherit;
    font: inherit;
    font-weight: 600;
    cursor: default;
    box-shadow:
      inset 1px 1px 0 rgba(255, 255, 255, 0.1),
      inset -1px -1px 0 rgba(0, 0, 0, 0.25);
  }

  .panel-menu-btn:hover {
    background: var(--wm-button-hover);
  }

  .panel-menu-btn:active {
    box-shadow:
      inset -1px -1px 0 rgba(255, 255, 255, 0.06),
      inset 1px 1px 0 rgba(0, 0, 0, 0.3);
  }

  .panel-menu-mark {
    color: var(--accent);
    font-size: 0.65rem;
  }

  .panel-tasks {
    display: flex;
    flex: 1;
    min-width: 0;
    gap: 3px;
    align-items: stretch;
    padding: 0 2px;
  }

  .panel-task {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    max-width: 200px;
    min-width: 100px;
    padding: 0 8px;
    border: 1px solid var(--wm-button-border);
    background: var(--wm-button-bg);
    color: inherit;
    font: inherit;
    cursor: default;
    box-shadow:
      inset 1px 1px 0 rgba(255, 255, 255, 0.08),
      inset -1px -1px 0 rgba(0, 0, 0, 0.2);
  }

  .panel-task.is-active {
    background: color-mix(in srgb, var(--wm-title-active-bg) 55%, var(--wm-button-bg));
    border-color: var(--wm-frame-active);
    box-shadow:
      inset -1px -1px 0 rgba(255, 255, 255, 0.05),
      inset 1px 1px 0 rgba(0, 0, 0, 0.25);
  }

  .panel-task-icon {
    color: var(--accent);
    font-weight: 700;
    font-size: 0.7rem;
  }

  .panel-task-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .panel-workspaces {
    display: flex;
    align-items: center;
    gap: 2px;
    padding: 0 4px;
  }

  .ws {
    min-width: 20px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--wm-button-border);
    background: var(--wm-button-bg);
    font-size: 0.72rem;
    color: var(--muted);
    box-shadow: inset 1px 1px 0 rgba(255, 255, 255, 0.05);
  }

  .ws.is-current {
    color: var(--wm-title-active-fg);
    background: var(--wm-title-active-bg);
    border-color: var(--wm-frame-active);
  }

  .panel-tray {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 6px;
    border: 1px solid var(--wm-panel-border);
    box-shadow: inset 1px 1px 0 rgba(0, 0, 0, 0.25);
    background: color-mix(in srgb, var(--wm-panel-bg) 80%, black);
    margin: 1px 0;
  }

  .panel-wm-name {
    font-size: 0.7rem;
    color: var(--muted);
    display: none;
  }

  @media (min-width: 640px) {
    .panel-wm-name {
      display: inline;
    }
  }

  .panel-clock {
    font-variant-numeric: tabular-nums;
    font-size: 0.78rem;
    white-space: nowrap;
  }

  /* Text selection inside terminal only */
  .desktop :global(.term) {
    user-select: text;
  }

  @media (max-width: 540px) {
    .desktop-icons {
      width: 72px;
    }

    .panel-task {
      min-width: 0;
      max-width: 120px;
    }

    .panel-workspaces {
      display: none;
    }
  }
</style>
